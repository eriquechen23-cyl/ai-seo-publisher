APP_NAME=AI SEO Publisher API
API_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
DATABASE_URL=sqlite:///backend/demo.db

# Gemini supports the OpenAI-compatible chat completions endpoint.
LLM_MODE=openai_compatible
LLM_API_BASE=https://generativelanguage.googleapis.com/v1beta/openai/
LLM_API_KEY=
LLM_MODEL=gemini-3.5-flash
LLM_TIMEOUT_SECONDS=30

RESEARCH_MODE=duckduckgo
RESEARCH_ROUTER_MODE=auto
DUCKDUCKGO_SEARCH_URL=https://html.duckduckgo.com/html/
SEARCH_RESULT_COUNT=5
SEARCH_TIMEOUT_SECONDS=10

WORDPRESS_URL=http://localhost:8080
WORDPRESS_USERNAME=demo_admin
WORDPRESS_APP_PASSWORD=
